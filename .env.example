# fake | claude | gemini | openai | deepseek | ollama
LLM_PROVIDER=fake

# Claude settings
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Gemini settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek settings
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Ollama settings (local, no API key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Knox: dynamic model selection (optional overrides)
# Format: provider:model (e.g. openai:gpt-4o-mini)
# MODEL_PLANNING=openai:gpt-4o-mini
# MODEL_SIMPLE=openai:gpt-4o-mini
# MODEL_MEDIUM=anthropic:claude-3-5-sonnet
# MODEL_COMPLEX=anthropic:claude-3-5-sonnet

# Knox: memory system
# MEMORY_PATH=docs/memory
# MEMORY_MAX_RUNS=500
